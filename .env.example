TELEGRAM_BOT_TOKEN=
MONGODB_URI=

AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

SUMMARY_DEFAULT_MESSAGE_COUNT=50
SUMMARY_DEFAULT_MINUTES=60
SUMMARY_DEFAULT_HOURS=12
SUMMARY_DEFAULT_DAYS=7

SUMMARY_MAX_MESSAGES=500
SUMMARY_MAX_CHARACTERS=50000
SUMMARY_MAX_TOKENS=4096

TRANSCRIPTION_BOT_USERNAME=
TRANSCRIPTION_BOT_USER_ID=
# Separate containers on the same server: use the host-published transcription port
TRANSCRIPTION_SERVICE_URL=http://host.docker.internal:4205
TRANSCRIPTION_TIMEOUT_MS=120000
TRANSCRIPTION_CONCURRENCY=3

# MongoDB Atlas M0 free tier: 512 MB storage (~100 ops/sec). Cleanup runs daily + on startup.
MESSAGE_RETENTION_DAYS=30
MESSAGE_MAX_TOTAL_DOCUMENTS=80000
MESSAGE_MAX_MESSAGES_PER_CHAT=10000
MESSAGE_CLEANUP_BATCH_SIZE=500
MESSAGE_CLEANUP_CRON=0 3 * * *
TIMEZONE=Europe/Kyiv

LOG_LEVEL=info
PORT=4206
NODE_ENV=production
ADMIN_TELEGRAM_ID=
DB_MESSAGES_COLLECTION=chat_messages
